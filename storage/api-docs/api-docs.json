                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Article detail"
                    },
                    "404": {
                        "description": "Article not found"
                    }
                }
            },
            "delete": {
