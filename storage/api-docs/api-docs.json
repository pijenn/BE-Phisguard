        "/admin/respons": {
            "post": {
                "tags": [
                    "Admin Response"
                ],
                "summary": "Create admin response for report",
                "operationId": "354f2964dd2a0255511c04c949f13165",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "report_id",
                                    "hasil_keputusan"
                                ],
                                "properties": {
                                    "report_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "hasil_keputusan": {
                                        "type": "string",
                                        "example": "Confirm Valid Phishing",
                                        "enum": [
                                            "Confirm Valid Phishing",
                                            "False Positive",
                                            "Need More Info"
                                        ]
                                    },
                                    "kategori": {
                                        "type": "string",
                                        "example": "Mengatasnamakan Bank",
                                        "enum": [
                                            "Mengatasnamakan Bank",
                                            "E-Wallet / Fintech",
                                            "OTP / Verifikasi Akun",
                                            "Hadiah / Undian",
                                            "Paket / Kurir",
                                            "Customer Service Palsu",
                                            "Investasi Bodong",
                                            "Akun Marketplace",
                                            "Typosquatting / Domain Palsu",
                                            "Lainnya"
                                        ]
                                    },
                                    "catatan": {
                                        "type": "string",
                                        "example": "Telah diverifikasi sebagai phishing valid"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Response created successfully"
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                }
            }
        },
