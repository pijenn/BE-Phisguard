                ],
                "summary": "Delete article",
                "operationId": "ec28483335ebdc4fd11f883fcf6f4487",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Article deleted successfully"
                    },
                    "404": {
                        "description": "Article not found"
                    }
                }
            },
            "patch": {
                "tags": [
                    "Articles"
                ],
                "summary": "Update educational article",
                "operationId": "98182cbd13556214028a5d193e7ebc5b",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "judul": {
                                        "type": "string",
                                        "example": "Waspada Phishing Via Email"
                                    },
                                    "kategori_artikel": {
                                        "type": "string",
                                        "enum": [
                                            "Tips",
                                            "Modus",
                                            "Update Kasus"
                                        ]
                                    },
                                    "gambar": {
                                        "description": "Image file (JPEG/PNG)",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "alt_text": {
                                        "type": "string"
                                    },
                                    "isi_artikel": {
                                        "type": "string"
                                    },
                                    "rangkuman": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Article updated successfully"
                    },
                    "404": {
                        "description": "Article not found"
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                }
            }
        },
        "/report": {
            "post": {
                "tags": [
                    "Report"
                ],
                "summary": "Submit phishing report",
                "operationId": "4b64511eec46a94d687d3f3f174bc9c0",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "channel_chat",
                                    "sender_account",
                                    "chat_text"
                                ],
                                "properties": {
                                    "channel_chat": {
                                        "type": "string",
                                        "example": "WhatsApp"
                                    },
                                    "sender_account": {
                                        "type": "string",
                                        "example": "08123456789"
                                    },
                                    "chat_text": {
                                        "type": "string",
                                        "example": "Klik link hadiah ini"
                                    },
                                    "url": {
                                        "type": "string",
                                        "example": "http://phishing.com"
                                    },
                                    "reporter_name": {
                                        "type": "string",
                                        "example": "Pijen"
                                    },
                                    "region": {
                                        "type": "string",
                                        "example": "Jakarta"
                                    },
                                    "interaksi": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "incident_summary": {
                                        "type": "string",
                                        "example": "Pengguna menerima pesan phishing dan mengklik link"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Report submitted successfully"
                    }
                }
            }
        },
